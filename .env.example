# ═══════════════════════════════════════════════
# LLM Provider 配置
# 复制本文件为 .env 并填入你的真实 API Key
# ═══════════════════════════════════════════════

# 选择使用的 Provider（deepseek | sjtu_zhiyuan）
LLM_PROVIDER=deepseek

# 当前使用的模型（可覆盖 Provider 默认值）
# LLM_MODEL=deepseek-chat

# ── DeepSeek 官方 API ─────────────────────────
DEEPSEEK_API_KEY=***
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com

# ── SJTU 致远一号 (校园网/VPN) ─────────────────
# 申请地址: https://my.sjtu.edu.cn/ → 搜索"致远一号"
# 文档: https://chat.sjtu.edu.cn/docs
SJTU_API_KEY=***
SJTU_API_ENDPOINT=https://models.sjtu.edu.cn/api/v1
